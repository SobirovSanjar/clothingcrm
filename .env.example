# Copy this file to .env and adjust as needed.

# Async PostgreSQL connection string (driver must be asyncpg).
DATABASE_URL=postgresql+asyncpg://crm:crm@localhost:5432/crm

# Secret used to sign session cookies. Use a long random value in production.
SECRET_KEY=change-this-to-a-long-random-string

# Optional overrides
APP_NAME=ClothCRM
SESSION_MAX_AGE=28800
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
